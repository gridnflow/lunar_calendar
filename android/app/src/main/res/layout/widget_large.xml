<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- 헤더: 양력 날짜 -->
    <TextView
        android:id="@+id/widget_solar_full"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="----년 --월 --일"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FF000000" />

    <!-- 음력 날짜 -->
    <TextView
        android:id="@+id/widget_lunar_full"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="음력 --월 --일"
        android:textSize="13sp"
        android:textColor="#AA000000" />

    <!-- 절기 -->
    <TextView
        android:id="@+id/widget_solar_term"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textSize="12sp"
        android:textColor="#FF6200EE" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#22000000" />

    <!-- 사주 행 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="사주 (四柱)"
        android:textSize="11sp"
        android:textColor="#AA000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:weightSum="4">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="年" android:textSize="10sp" android:textColor="#AA000000" />
            <TextView android:id="@+id/widget_saju_year"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#FF000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="月" android:textSize="10sp" android:textColor="#AA000000" />
            <TextView android:id="@+id/widget_saju_month"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#FF000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="日" android:textSize="10sp" android:textColor="#AA000000" />
            <TextView android:id="@+id/widget_saju_day"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#FF000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="時" android:textSize="10sp" android:textColor="#AA000000" />
            <TextView android:id="@+id/widget_saju_hour"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#FF000000" />
        </LinearLayout>

    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="#22000000" />

    <!-- 오늘의 운세 요약 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘의 운세"
        android:textSize="11sp"
        android:textColor="#AA000000" />

    <TextView
        android:id="@+id/widget_fortune"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:text="앱을 열어 운세를 불러오세요"
        android:textSize="12sp"
        android:textColor="#DD000000"
        android:lineSpacingMultiplier="1.4"
        android:maxLines="5"
        android:ellipsize="end" />

</LinearLayout>
