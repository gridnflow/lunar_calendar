rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 본인만 자기 프로필과 하위 컬렉션(기념일 등)에 접근 가능
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
